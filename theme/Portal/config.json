{
    "name": "Portal",
    "description": "",
    "version": "1.0.13",
    "images": "",
    "configs": [
        {
            "label": "主题色",
            "placeholder": "请选择主题颜色",
            "field_name": "theme_color",
            "field_type": "select",
            "select_options": {
                "default": "默认(绿色)",
                "blue": "蓝色",
                "black": "黑色",
                "darkblue": "暗蓝色"
            },
            "default_value": "black"
        },
        {
            "label": "站点标题",
            "placeholder": "可以修改站点标题，留空则使用面板标题",
            "field_name": "title",
            "field_type": "input",
            "default_value": ""
        },
        {
            "label": "API 地址",
            "placeholder": "可自定义API地址，一般默认即可",
            "field_name": "api_url",
            "field_type": "input",
            "default_value": "/"
        },
        {
            "label": "背景",
            "placeholder": "请输入背景图片URL",
            "field_name": "background_url",
            "field_type": "input"
        },
        {
            "label": "自定义页脚HTML",
            "placeholder": "可以实现客服JS代码的加入等",
            "field_name": "custom_html",
            "field_type": "textarea"
        },
        {
            "label": "显示支付方式标题",
            "placeholder": "控制在有图标时是否仍显示支付方式的名称",
            "field_name": "show_payment_title",
            "field_type": "select",
            "select_options": {
                "true": "显示",
                "false": "不显示"
            },
            "default_value": "false"
        },
        {
            "label": "隐藏礼品卡菜单",
            "placeholder": "控制是否在侧边栏隐藏礼品卡菜单",
            "field_name": "hide_gift_card_menu",
            "field_type": "select",
            "select_options": {
                "true": "隐藏",
                "false": "显示"
            },
            "default_value": "false"
        }
    ],
    "title": ""
}
