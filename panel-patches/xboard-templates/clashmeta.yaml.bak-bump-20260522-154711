  prefer-h3: false
  respect-rules: true
  use-hosts: true
  use-system-hosts: true
  ipv6: false
  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "*.arpa"
    - "localhost"
    - "localhost.localdomain"
    - "router.asus.com"
    - "routerlogin.net"
    - "captive.apple.com"
    - "+.push.apple.com"
    - "+.icloud.com"
    - "+.apple.com"
    - "msftconnecttest.com"
    - "www.msftconnecttest.com"
    - "+.msftncsi.com"
    - "connectivitycheck.gstatic.com"
    - "connectivitycheck.android.com"
    - "clients3.google.com"
    - "clients4.google.com"
    - "android.clients.google.com"
    - "time.*"
    - "ntp.*"
    - "+.market.xiaomi.com"
    - "localhost.ptlogin2.qq.com"
    - "Mijia Cloud"
    - "+._dns-sd._udp.*"
    - "+._services._dns-sd._udp.*"
